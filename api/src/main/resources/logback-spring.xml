<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback config for the PluginFactory API.

    Console pattern includes MDC keys (requestId, userId, sessionId) so every
    line that runs inside an HTTP request or build pipeline carries the
    correlation keys you need to trace a failure back to a session/user.

    File appender rotates daily and on size, keeping ~90 days of history with a
    1.5GB total cap — enough to replay incidents without filling the volume.
    Disable by setting LOG_FILE_PATH= empty (file appender is gated by a
    Spring profile-aware property below).
-->
<configuration>

    <springProperty scope="context" name="LOG_FILE_PATH" source="logging.file.path" defaultValue="logs"/>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="pluginfactory-api"/>

    <property name="MDC_KEYS"
              value="req=%X{requestId:-} user=%X{userId:-} session=%X{sessionId:-}"/>

    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] [${MDC_KEYS}] %logger{36} - %msg%n"/>

    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] [${MDC_KEYS}] %logger - %msg%n%xThrowable"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE_PATH}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>1500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <logger name="com.bekololek.pluginfactory" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>
    <logger name="org.hibernate.SQL" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
