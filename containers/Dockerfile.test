FROM eclipse-temurin:17-jre-jammy

RUN apt-get update && apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

ARG PAPER_VERSION=1.20.4
ARG PAPER_BUILD=496
RUN mkdir -p /server && \
    curl -o /server/paper.jar \
    "https://api.papermc.io/v2/projects/paper/versions/${PAPER_VERSION}/builds/${PAPER_BUILD}/downloads/paper-${PAPER_VERSION}-${PAPER_BUILD}.jar" || true

RUN useradd -r -m tester
WORKDIR /server
RUN echo "eula=true" > eula.txt && chown -R tester:tester /server
USER tester
VOLUME /server/plugins
